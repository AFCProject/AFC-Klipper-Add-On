# Config tests invalid buffer setup where buffer is set as pin_tool_start and
# buffer name is set in AFC_extruder but AFC_buffer TN config does not exist

# AFC should correctly detect this error and raise an error that causes klipper
# to stop loading.

# Setup is for lanes defined with AFC_lane like setups
DICTIONARY stm32h723.dict
CONFIG afc_extruder_buffer_not_found_AFC_lane.cfg

# Test should fail because klipper should raise an error
SHOULD_FAIL